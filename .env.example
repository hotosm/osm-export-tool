# OSM Export Tool Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# General Settings
# =============================================================================
DEBUG=false
SECRET_KEY=your-secret-key-here
HOSTNAME=localhost
DJANGO_ENV=development

# =============================================================================
# Database
# =============================================================================
DATABASE_URL=postgis://user:password@localhost:5432/exports

# =============================================================================
# Authentication Provider
# =============================================================================
# Options: "legacy" (OSM OAuth2) or "hanko" (Hanko SSO)
AUTH_PROVIDER=legacy

# -----------------------------------------------------------------------------
# Legacy Authentication (OSM OAuth2)
# Required when AUTH_PROVIDER=legacy
# -----------------------------------------------------------------------------
OSM_API_KEY=your-osm-api-key
OSM_API_SECRET=your-osm-api-secret

# -----------------------------------------------------------------------------
# Hanko SSO Authentication
# Required when AUTH_PROVIDER=hanko
# -----------------------------------------------------------------------------
HANKO_API_URL=https://login.hotosm.org
HANKO_PUBLIC_URL=https://login.hotosm.org
COOKIE_SECRET=your-32-byte-secret-key-here
COOKIE_DOMAIN=.hotosm.org
COOKIE_SECURE=true

# Admin emails for Hanko SSO (comma-separated list)
# Users with these emails will have superuser permissions
ADMIN_EMAILS=admin@hotosm.org,admin2@hotosm.org

# =============================================================================
# External Services
# =============================================================================
# Overpass API
OVERPASS_API_URL=http://overpass-api.de/api/

# Raw Data API
RAW_DATA_API_URL=https://api-stage.raw-data.hotosm.org/
RAW_DATA_ACCESS_TOKEN=your-raw-data-api-token

# GeoNames
GEONAMES_API_URL=http://api.geonames.org/searchJSON

# Nominatim
NOMINATIM_API_URL=https://nominatim.openstreetmap.org/search.php

# Tasking Manager
TASKING_MANAGER_API_URL=https://tasking-manager-tm4-production-api.hotosm.org/api/v2/projects

# =============================================================================
# HDX Integration
# =============================================================================
SYNC_TO_HDX=false
USE_RAW_DATA_API_FOR_HDX=true
HDX_API_KEY=your-hdx-api-key
HDX_NOTIFICATION_EMAIL=notifications@example.com
HDX_SITE=demo

# =============================================================================
# Email Configuration
# =============================================================================
EMAIL_HOST=smtp.example.com
EMAIL_HOST_USER=user@example.com
EMAIL_HOST_PASSWORD=your-email-password
EMAIL_PORT=587
EMAIL_USE_TLS=true
REPLY_TO_EMAIL=noreply@example.com

# =============================================================================
# Analytics (Optional)
# =============================================================================
MATOMO_URL=
MATOMO_SITEID=

# =============================================================================
# Worker Configuration
# =============================================================================
WORKER_SECRET_KEY=your-worker-secret-key

# =============================================================================
# Export Configuration
# =============================================================================
EXPORT_STAGING_ROOT=/path/to/export_staging/
EXPORT_DOWNLOAD_ROOT=/path/to/export_downloads/

# =============================================================================
# Tool Paths (Optional)
# =============================================================================
OSMAND_MAP_CREATOR_DIR=/usr/local/OsmAndMapCreator
GARMIN_SPLITTER=/usr/local/splitter/splitter.jar
GARMIN_MKGMAP=/usr/local/mkgmap/mkgmap.jar
GENERATE_MWM=/usr/local/bin/generate_mwm.sh
GENERATOR_TOOL=/usr/local/bin/generator_tool
PLANET_FILE=
